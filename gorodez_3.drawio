          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- C3 → M7 (client gives passport) -->
        <mxCell id="MF_C3_M7" parent="PROC" edge="1" source="C3" target="M7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#A8201A;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- M8 → S5 (manager sends client data to system) -->
        <mxCell id="MF_M8_S5" parent="PROC" edge="1" source="M8" target="S5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#A8201A;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- S7 → M9 (system sends ready agreement) -->
        <mxCell id="MF_S7_M9" parent="PROC" edge="1" source="S7" target="M9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#A8201A;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- M10 → C4 (manager sends agreement to client) -->
        <mxCell id="MF_M10_C4" parent="PROC" edge="1" source="M10" target="C4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#A8201A;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- C5 → M11 (client returns signed agreement + payment) -->
        <mxCell id="MF_C5_M11" parent="PROC" edge="1" source="C5" target="M11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#A8201A;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- M12 → S8 (manager records payment in system) -->
        <mxCell id="MF_M12_S8" parent="PROC" edge="1" source="M12" target="S8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#A8201A;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- S10 → M13 (system sends confirmation) -->
        <mxCell id="MF_S10_M13" parent="PROC" edge="1" source="S10" target="M13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#A8201A;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- M15 → C6 (manager issues tool to client) -->
