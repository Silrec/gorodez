        </mxCell>

        <!-- S4YES → M3 (system responds: available) -->
        <mxCell id="MF_S4YES_M3" parent="PROC" edge="1" source="S4YES" target="M3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#A8201A;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- S4NO → M3 (system responds: unavailable) — goes to the same event -->
        <mxCell id="MF_S4NO_M3" parent="PROC" edge="1" source="S4NO" target="M3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#A8201A;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- M6 → C2 (manager notifies client: available) -->
