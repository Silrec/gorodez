        </mxCell>

        <!-- M2 → S1 (manager queries system) -->
        <mxCell id="MF_M2_S1" parent="PROC" edge="1" source="M2" target="S1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#A8201A;">
