        <!-- ========== MESSAGE FLOWS (cross-lane, parent=PROC) ========== -->

        <!-- C1 → M1 (client arrives, manager gets request) -->
        <mxCell id="MF_C1_M1" parent="PROC" edge="1" source="C1" target="M1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#A8201A;">
